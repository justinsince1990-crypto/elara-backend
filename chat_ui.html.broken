<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Elara</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f0f0f; color: #e5e5e5; }
        .elara-msg { background-color: #1e1e1e; border-radius: 1rem; padding: 1rem; }
        .user-msg { background-color: #0b4d3c; border-radius: 1rem; padding: 1rem; }
    </style>
</head>
<body class="h-screen flex flex-col font-sans">
    <main id="chat-box" class="flex-1 overflow-y-auto p-4 space-y-4"></main>
    <div class="p-4 border-t border-gray-800 flex gap-2">
        <input id="prompt" class="flex-1 bg-gray-900 rounded p-2 text-sm" placeholder="Message...">
        <button id="send-btn" class="bg-emerald-600 px-4 py-2 rounded text-sm font-bold">Send</button>
    </div>
    <script>
        const chatBox = document.getElementById("chat-box");
        async function load() {
            const res = await fetch("/history");
            const data = await res.json();
            chatBox.innerHTML = (data.history || []).map(m => `
                <div class="flex ${m.role === 'user' ? 'justify-end' : 'justify-start'}">
                    <div class="${m.role === 'user' ? 'user-msg' : 'elara-msg'} max-w-[80%] cursor-pointer" onclick="play('${m.audio_url || ''}')">
                        ${m.content} ${m.audio_url ? '🎵' : ''}
                    </div>
                </div>`).join("");
            chatBox.scrollTop = chatBox.scrollHeight;
        }
        async function play(url) { if (url) new Audio(url).play(); }
        document.getElementById("send-btn").onclick = async () => {
            const p = document.getElementById("prompt");
            await fetch("/chat", {method: "POST", headers: {"Content-Type": "application/json"}, body: JSON.stringify({message: p.value})});
            p.value = "";
            load();
        };
        load();
    </script>
</body>
</html>
